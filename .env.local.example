# Copy to .env.local and fill in to enable real email login + cloud saves.
# Without these, the game runs with a local dev fallback (email sign-in is faked,
# saves go to the browser's localStorage). No code change needed to go live.
#
# Setup:
#   1. Create a free project at https://supabase.com
#   2. SQL editor → run supabase/schema.sql
#   3. Authentication → Providers → enable Email (magic link)
#   4. Authentication → URL Configuration → add http://localhost:3000 (and your prod URL)
#   5. Project Settings → API → copy the values below

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
